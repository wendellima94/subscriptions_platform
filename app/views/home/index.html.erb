<% if user_signed_in? && current_user.role_admin? %>
  <section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
          Painel administrativo
        </p>

        <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">
          Gerencie a operação da plataforma.
        </h1>

        <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">
          Acompanhe planos, assinaturas e invoices em um único lugar.
          Use os atalhos abaixo para administrar o ciclo de cobrança.
        </p>
      </div>

      <div class="rounded-2xl bg-slate-50 p-5">
        <p class="text-sm text-slate-500">
          Logado como
        </p>

        <p class="mt-1 text-lg font-semibold text-slate-900">
          <%= current_user.name %>
        </p>

        <p class="text-sm text-slate-500">
          <%= current_user.email %>
        </p>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-6 md:grid-cols-3">
    <%= link_to admin_plans_path, class: "rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-blue-200 hover:shadow-md" do %>
      <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
        Planos
      </p>

      <h2 class="mt-3 text-xl font-semibold text-slate-900">
        Gerenciar planos
      </h2>

      <p class="mt-2 text-sm leading-6 text-slate-600">
        Cadastre, edite, ative ou inative planos disponíveis para assinatura.
      </p>

      <p class="mt-5 text-sm font-semibold text-blue-600">
        Acessar planos →
      </p>
    <% end %>

    <%= link_to admin_subscriptions_path, class: "rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-blue-200 hover:shadow-md" do %>
      <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
        Assinaturas
      </p>

      <h2 class="mt-3 text-xl font-semibold text-slate-900">
        Acompanhar clientes
      </h2>

      <p class="mt-2 text-sm leading-6 text-slate-600">
        Visualize assinaturas por status e acompanhe clientes ativos ou cancelados.
      </p>

      <p class="mt-5 text-sm font-semibold text-blue-600">
        Ver assinaturas →
      </p>
    <% end %>

    <%= link_to admin_invoices_path, class: "rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-blue-200 hover:shadow-md" do %>
      <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
        Invoices
      </p>

      <h2 class="mt-3 text-xl font-semibold text-slate-900">
        Monitorar cobranças
      </h2>

      <p class="mt-2 text-sm leading-6 text-slate-600">
        Filtre cobranças por status ou mês de referência e acompanhe pagamentos.
      </p>

      <p class="mt-5 text-sm font-semibold text-blue-600">
        Ver invoices →
      </p>
    <% end %>
  </section>
<% elsif user_signed_in? %>
  <% active_subscription = current_user.subscriptions.active.includes(:plan, :invoices).first %>
  <% next_invoice = active_subscription&.invoices&.open&.order(:reference_month)&.first %>

  <section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
    <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr] lg:items-center">
      <div>
        <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
          Área do cliente
        </p>

        <% if active_subscription.present? %>
          <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">
            Sua assinatura está ativa.
          </h1>

          <p class="mt-4 text-lg leading-8 text-slate-600">
            Acompanhe seu plano atual, veja suas cobranças e mantenha seus pagamentos em dia.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <%= link_to "Minha assinatura",
                        subscription_path,
                        class: "rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>

            <%= link_to "Ver planos",
                        plans_path,
                        class: "rounded-lg border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
          </div>
        <% else %>
          <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">
            Escolha um plano para começar.
          </h1>

          <p class="mt-4 text-lg leading-8 text-slate-600">
            Você ainda não possui uma assinatura ativa. Selecione um plano para ativar sua conta e gerar a primeira invoice.
          </p>

          <div class="mt-8">
            <%= link_to "Ver planos disponíveis",
                        plans_path,
                        class: "rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
          </div>
        <% end %>
      </div>

      <div class="rounded-2xl bg-slate-50 p-6">
        <h2 class="text-lg font-semibold text-slate-900">
          Resumo da conta
        </h2>

        <% if active_subscription.present? %>
          <dl class="mt-5 space-y-4 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Plano</dt>
              <dd class="font-medium text-slate-900"><%= active_subscription.plan.name %></dd>
            </div>

            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Status</dt>
              <dd class="font-medium text-slate-900"><%= active_subscription.status %></dd>
            </div>

            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Valor</dt>
              <dd class="font-medium text-slate-900">
                <%= number_to_currency(active_subscription.plan.price_cents / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
              </dd>
            </div>

            <div class="border-t border-slate-200 pt-4">
              <dt class="text-slate-500">Próxima cobrança em aberto</dt>

              <% if next_invoice.present? %>
                <dd class="mt-2 font-medium text-slate-900">
                  <%= number_to_currency(next_invoice.amount_cents / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
                  vencendo em <%= l(next_invoice.due_on) %>
                </dd>
              <% else %>
                <dd class="mt-2 font-medium text-green-700">
                  Nenhuma cobrança em aberto.
                </dd>
              <% end %>
            </div>
          </dl>
        <% else %>
          <p class="mt-4 text-sm leading-6 text-slate-600">
            Após escolher um plano, sua assinatura aparecerá aqui com informações de status, valor e invoices.
          </p>
        <% end %>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-6 md:grid-cols-3">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">
        1. Escolha um plano
      </h2>

      <p class="mt-2 text-sm leading-6 text-slate-600">
        Compare as opções disponíveis e ative a assinatura que melhor atende sua necessidade.
      </p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">
        2. Acompanhe invoices
      </h2>

      <p class="mt-2 text-sm leading-6 text-slate-600">
        Visualize cobranças em aberto, pagas ou expiradas diretamente na sua assinatura.
      </p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">
        3. Gerencie sua assinatura
      </h2>

      <p class="mt-2 text-sm leading-6 text-slate-600">
        Você pode cancelar sua assinatura quando necessário, sem apagar o histórico de cobranças.
      </p>
    </div>
  </section>
<% else %>
  <section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
    <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr] lg:items-center">
      <div>
        <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
          Plataforma de assinaturas
        </p>

        <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">
          Gerencie planos, assinaturas e cobranças recorrentes.
        </h1>

        <p class="mt-4 text-lg leading-8 text-slate-600">
          Entre para acessar sua assinatura, acompanhar invoices ou administrar a operação da plataforma.
        </p>

        <div class="mt-8">
          <%= link_to "Entrar na plataforma",
                      login_path,
                      class: "rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
        </div>
      </div>

      <div class="rounded-2xl bg-slate-50 p-6">
        <h2 class="text-lg font-semibold text-slate-900">
          O que a plataforma cobre?
        </h2>

        <ul class="mt-5 space-y-3 text-sm text-slate-600">
          <li>• Catálogo de planos ativos</li>
          <li>• Ativação e cancelamento de assinaturas</li>
          <li>• Geração mensal de invoices</li>
          <li>• Pagamento manual de cobranças</li>
          <li>• Painel administrativo com filtros</li>
        </ul>
      </div>
    </div>
  </section>
<% end %>