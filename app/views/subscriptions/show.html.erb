<div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
      Área do cliente
    </p>

    <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900">
      Minha assinatura
    </h1>

    <p class="mt-2 text-slate-600">
      Acompanhe seu plano atual, cobranças e pagamentos.
    </p>
  </div>

  <%= link_to "Ver planos",
              plans_path,
              class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
</div>

<% if @subscription.blank? %>
  <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-8 text-center shadow-sm">
    <h2 class="text-xl font-semibold text-slate-900">
      Você ainda não possui uma assinatura ativa.
    </h2>

    <p class="mt-3 text-slate-600">
      Escolha um plano para ativar sua assinatura e começar a gerar invoices.
    </p>

    <div class="mt-6">
      <%= link_to "Escolher plano",
                  plans_path,
                  class: "rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
    </div>
  </div>
<% else %>
  <section class="grid gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="text-sm font-medium text-slate-500">
            Plano atual
          </p>

          <h2 class="mt-1 text-2xl font-bold text-slate-900">
            <%= @subscription.plan.name %>
          </h2>

          <p class="mt-2 text-sm text-slate-600">
            Assinatura iniciada em
            <%= l(@subscription.started_at.to_date) %>
          </p>
        </div>

        <span class="inline-flex rounded-full bg-green-50 px-3 py-1 text-sm font-medium text-green-700">
          <%= @subscription.status %>
        </span>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-4">
          <p class="text-sm text-slate-500">
            Valor
          </p>

          <p class="mt-1 text-lg font-semibold text-slate-900">
            <%= number_to_currency(@subscription.plan.price_cents / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
          </p>
        </div>

        <div class="rounded-xl bg-slate-50 p-4">
          <p class="text-sm text-slate-500">
            Periodicidade
          </p>

          <p class="mt-1 text-lg font-semibold text-slate-900">
            <%= @subscription.plan.monthly? ? "Mensal" : "Trimestral" %>
          </p>
        </div>

        <div class="rounded-xl bg-slate-50 p-4">
          <p class="text-sm text-slate-500">
            Invoices
          </p>

          <p class="mt-1 text-lg font-semibold text-slate-900">
            <%= @invoices.count %>
          </p>
        </div>
      </div>

      <div class="mt-6 flex flex-col gap-3 border-t border-slate-200 pt-6 sm:flex-row">
        <%= button_to "Gerar próxima invoice",
                      generate_next_invoice_subscription_path,
                      method: :post,
                      class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>

        <%= button_to "Cancelar assinatura",
                      subscription_path,
                      method: :delete,
                      data: { turbo_confirm: "Tem certeza que deseja cancelar sua assinatura?" },
                      class: "rounded-lg border border-red-300 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" %>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h3 class="text-lg font-semibold text-slate-900">
        Resumo
      </h3>

      <dl class="mt-4 space-y-4 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Status</dt>
          <dd class="font-medium text-slate-900"><%= @subscription.status %></dd>
        </div>

        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Plano</dt>
          <dd class="font-medium text-slate-900"><%= @subscription.plan.name %></dd>
        </div>

        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Preço</dt>
          <dd class="font-medium text-slate-900">
            <%= number_to_currency(@subscription.plan.price_cents / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="mt-8 rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-200 px-6 py-4">
      <h2 class="text-lg font-semibold text-slate-900">
        Invoices
      </h2>

      <p class="mt-1 text-sm text-slate-600">
        Histórico de cobranças da sua assinatura.
      </p>
    </div>

    <% if @invoices.empty? %>
      <div class="p-6 text-sm text-slate-600">
        Nenhuma invoice encontrada.
      </div>
    <% else %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                Mês
              </th>

              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                Valor
              </th>

              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                Vencimento
              </th>

              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                Status
              </th>

              <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">
                Ações
              </th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-200 bg-white">
            <% payable_invoice = @invoices.select(&:open?).min_by(&:reference_month) %>
            <% @invoices.each do |invoice| %>
              <tr>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700">
                  <%= l(invoice.reference_month, format: "%B/%Y") %>
                </td>

                <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-slate-900">
                  <%= number_to_currency(invoice.amount_cents / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
                </td>

                <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700">
                  <%= l(invoice.due_on) %>
                </td>

                <td class="whitespace-nowrap px-6 py-4 text-sm">
                  <% if invoice.paid? %>
                    <span class="rounded-full bg-green-50 px-3 py-1 text-xs font-medium text-green-700">
                      paid
                    </span>
                  <% elsif invoice.expired? %>
                    <span class="rounded-full bg-red-50 px-3 py-1 text-xs font-medium text-red-700">
                      expired
                    </span>
                  <% else %>
                    <span class="rounded-full bg-yellow-50 px-3 py-1 text-xs font-medium text-yellow-700">
                      open
                    </span>
                  <% end %>
                </td>

                <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
                 
                  <% if invoice.open? && invoice == payable_invoice %>
                    <%= button_to "Pagar",
                                  pay_invoice_path(invoice),
                                  method: :post,
                                  class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
                  <% elsif invoice.open? %>
                    <span class="text-xs text-slate-400">
                      Pague invoices anteriores primeiro
                    </span>
                  <% else %>
                    <span class="text-slate-400">
                      —
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>
<% end %>