<div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
      Catálogo
    </p>

    <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900">
      Planos disponíveis
    </h1>

    <p class="mt-2 text-slate-600">
      Escolha o plano que melhor combina com sua necessidade.
    </p>
  </div>

  <% if @active_subscription.present? %>
    <div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
      Você já possui uma assinatura ativa.
    </div>
  <% end %>
</div>

<div class="grid gap-6 md:grid-cols-3">
  <% @plans.each do |plan| %>
    <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div>
        <div class="flex items-center justify-between gap-4">
          <h2 class="text-xl font-semibold text-slate-900">
            <%= plan.name %>
          </h2>

          <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700">
            <%= plan.periodicity == "monthly" ? "Mensal" : "Trimestral" %>
          </span>
        </div>

        <div class="mt-6">
          <span class="text-4xl font-bold tracking-tight text-slate-900">
            <%= number_to_currency(plan.price_cents / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
          </span>

          <span class="text-sm text-slate-500">
            / <%= plan.monthly? ? "mês" : "trimestre" %>
          </span>
        </div>

        <p class="mt-4 text-sm leading-6 text-slate-600">
          Plano com cobrança recorrente, geração automática de invoices e controle de assinatura.
        </p>
      </div>

      <div class="mt-8">
        <% if @active_subscription.present? %>
          <% if @active_subscription.plan_id == plan.id %>
            <button class="w-full rounded-lg bg-green-100 px-4 py-3 text-sm font-semibold text-green-700" disabled>
              Plano atual
            </button>
          <% else %>
            <button class="w-full rounded-lg bg-slate-100 px-4 py-3 text-sm font-semibold text-slate-500" disabled>
              Já possui assinatura
            </button>
          <% end %>
        <% else %>
          <%= button_to "Assinar plano",
                        subscriptions_path(plan_id: plan.id),
                        method: :post,
                        class: "w-full rounded-lg bg-blue-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>