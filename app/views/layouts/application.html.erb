<!DOCTYPE html>
<html>
  <head>
    <title>Subscriptions Platform</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

<body class="min-h-screen bg-slate-50 text-slate-900">
  <header class="border-b border-slate-200 bg-white">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <%= link_to "Subscriptions Platform", root_path, class: "text-lg font-semibold text-slate-900" %>

      <!-- Menu desktop -->
      <nav class="hidden items-center gap-4 text-sm lg:flex">
        <%= link_to "Home", root_path, class: "text-slate-600 hover:text-slate-900" %>

        <% if user_signed_in? %>
          <%= link_to "Planos", plans_path, class: "text-slate-600 hover:text-slate-900" %>
          <%= link_to "Minha assinatura", subscription_path, class: "text-slate-600 hover:text-slate-900" %>

          <% if current_user.role_admin? %>
            <%= link_to "Admin Planos", admin_plans_path, class: "text-slate-600 hover:text-slate-900" %>
            <%= link_to "Admin Assinaturas", admin_subscriptions_path, class: "text-slate-600 hover:text-slate-900" %>
            <%= link_to "Admin Invoices", admin_invoices_path, class: "text-slate-600 hover:text-slate-900" %>
          <% end %>

          <span class="hidden text-slate-400 sm:inline">
            |
          </span>

          <span class="hidden text-slate-600 sm:inline">
            <%= current_user.name %>
          </span>

          <%= button_to "Sair",
                        logout_path,
                        method: :delete,
                        form: { class: "inline" },
                        class: "rounded-lg border border-slate-300 px-3 py-2 font-medium text-slate-700 hover:bg-slate-100" %>
        <% else %>
          <%= link_to "Entrar",
                      login_path,
                      class: "rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white shadow-sm hover:bg-blue-700" %>
        <% end %>
      </nav>

      <!-- Menu mobile -->
      <details class="relative lg:hidden">
        <summary class="flex cursor-pointer list-none items-center gap-2 rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100">
          Menu

          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </summary>

        <div class="absolute right-0 z-50 mt-3 w-64 rounded-xl border border-slate-200 bg-white p-3 shadow-lg">
          <nav class="flex flex-col gap-1 text-sm">
            <%= link_to "Home",
                        root_path,
                        class: "rounded-lg px-3 py-2 text-slate-700 hover:bg-slate-100" %>

            <% if user_signed_in? %>
              <%= link_to "Planos",
                          plans_path,
                          class: "rounded-lg px-3 py-2 text-slate-700 hover:bg-slate-100" %>

              <%= link_to "Minha assinatura",
                          subscription_path,
                          class: "rounded-lg px-3 py-2 text-slate-700 hover:bg-slate-100" %>

              <% if current_user.role_admin? %>
                <div class="my-2 border-t border-slate-200"></div>

                <p class="px-3 py-1 text-xs font-semibold uppercase tracking-wide text-slate-400">
                  Admin
                </p>

                <%= link_to "Admin Planos",
                            admin_plans_path,
                            class: "rounded-lg px-3 py-2 text-slate-700 hover:bg-slate-100" %>

                <%= link_to "Admin Assinaturas",
                            admin_subscriptions_path,
                            class: "rounded-lg px-3 py-2 text-slate-700 hover:bg-slate-100" %>

                <%= link_to "Admin Invoices",
                            admin_invoices_path,
                            class: "rounded-lg px-3 py-2 text-slate-700 hover:bg-slate-100" %>
              <% end %>

              <div class="my-2 border-t border-slate-200"></div>

              <div class="px-3 py-2 text-slate-600">
                <%= current_user.name %>
              </div>

              <%= button_to "Sair",
                            logout_path,
                            method: :delete,
                            form: { class: "mt-1" },
                            class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-left font-medium text-slate-700 hover:bg-slate-100" %>
            <% else %>
              <%= link_to "Entrar",
                          login_path,
                          class: "rounded-lg bg-blue-600 px-3 py-2 text-center font-semibold text-white shadow-sm hover:bg-blue-700" %>
            <% end %>
          </nav>
        </div>
      </details>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-6 py-8">
    <% if notice.present? %>
      <div class="mb-4 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
        <%= notice %>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>
  </main>
</body>
</html>