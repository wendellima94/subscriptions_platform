<!DOCTYPE html>
<html>
  <head>
    <title>Subscriptions Platform</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <%= link_to "Subscriptions Platform", root_path, class: "text-lg font-semibold text-slate-900" %>

        <nav class="flex items-center gap-4 text-sm">
          <%= link_to "Planos", "#", class: "text-slate-600 hover:text-slate-900" %>
          <%= link_to "Assinaturas", "#", class: "text-slate-600 hover:text-slate-900" %>
          <%= link_to "Invoices", "#", class: "text-slate-600 hover:text-slate-900" %>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-8">
      <% if notice.present? %>
        <div class="mb-4 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
          <%= notice %>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>