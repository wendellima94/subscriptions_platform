<%= form_with model: [:admin, @plan], class: "space-y-6" do |form| %>
  <% if @plan.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      <p class="font-semibold">
        Não foi possível salvar o plano:
      </p>

      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% @plan.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Nome", class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_field :name,
                        class: "mt-2 block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 shadow-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100",
                        placeholder: "Profissional" %>
  </div>

  <div>
    <%= form.label :periodicity, "Periodicidade", class: "block text-sm font-medium text-slate-700" %>
    <%= form.select :periodicity,
                    Plan.periodicities.keys.map { |periodicity| [periodicity == "monthly" ? "Mensal" : "Trimestral", periodicity] },
                    {},
                    class: "mt-2 block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 shadow-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" %>
  </div>

  <div>
    <%= form.label :price_cents, "Preço em centavos", class: "block text-sm font-medium text-slate-700" %>
    <%= form.number_field :price_cents,
                          min: 1,
                          class: "mt-2 block w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 shadow-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100",
                          placeholder: "5990" %>

    <p class="mt-2 text-xs text-slate-500">
      Exemplo: 5990 representa R$ 59,90.
    </p>
  </div>

  <div class="flex items-center gap-3">
    <%= form.check_box :active,
                       class: "h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>

    <%= form.label :active, "Plano ativo", class: "text-sm font-medium text-slate-700" %>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-slate-200 pt-6">
    <%= link_to "Cancelar",
                admin_plans_path,
                class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>

    <%= form.submit "Salvar plano",
                    class: "rounded-lg bg-blue-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
  </div>
<% end %>