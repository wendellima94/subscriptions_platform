<div class="mx-auto max-w-md">
  <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
    <div class="mb-8">
      <p class="text-sm font-medium uppercase tracking-wide text-blue-600">
        Acesso
      </p>

      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900">
        Entrar na plataforma
      </h1>

      <p class="mt-2 text-sm leading-6 text-slate-600">
        Use as credenciais criadas no seed para acessar como admin ou customer.
      </p>
    </div>

    <%= form_with url: login_path, method: :post, class: "space-y-5" do %>
      <div>
        <%= label_tag :email, "E-mail", class: "block text-sm font-medium text-slate-700" %>

        <%= email_field_tag :email,
                            params[:email],
                            required: true,
                            autofocus: true,
                            class: "mt-2 block w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 shadow-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" %>
      </div>

      <div>
        <%= label_tag :password, "Senha", class: "block text-sm font-medium text-slate-700" %>

        <%= password_field_tag :password,
                               nil,
                               required: true,
                               class: "mt-2 block w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 shadow-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200" %>
      </div>

      <%= submit_tag "Entrar",
                     class: "w-full rounded-lg bg-blue-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
    <% end %>
    </div>
  </div>
</div>